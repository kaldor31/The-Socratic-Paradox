# Neon PostgreSQL connection string (serverless driver compatible)
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# API server configuration
PORT=4000
NODE_ENV=development

# Optional: Neon connection pooling (use this in production if you prefer pooled)
DATABASE_POOL_URL=

# Auth secrets
JWT_SECRET=change-this-in-production

# SMTP (required for real emails; leave blank for local development to log codes)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@socratic-paradox.app
