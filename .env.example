# Neon PostgreSQL connection string (serverless driver compatible)
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# API server configuration
PORT=4000
NODE_ENV=development

# Optional: Neon connection pooling (use this in production if you prefer pooled)
DATABASE_POOL_URL=

# Auth secrets
JWT_SECRET=change-this-in-production

# Email provider (required for real emails in production)
# Resend is easiest: set RESEND_API_KEY and EMAIL_FROM to a verified domain address.
# Alternatively, set SMTP_* credentials.
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@socratic-paradox.app
