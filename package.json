{
  "name": "the-socratic-paradox",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive cognitive journal based on the Socratic Method (Maieutics).",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\" --names API,UI --prefix-colors cyan,magenta",
    "dev:api": "tsx watch src/index.ts",
    "dev:ui": "cd frontend && npm run dev",
    "build": "tsc && cd frontend && npm run build",
    "vercel-build": "npm run db:migrate && cd frontend && npm install --include=dev && npm run build",
    "postinstall": "cd frontend && npm install",
    "start": "node dist/index.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/migrate.ts --reset",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts database/**/*.sql"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "pino": "^9.0.0",
    "resend": "^6.16.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "globals": "^15.0.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^7.0.0"
  }
}
